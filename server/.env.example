PORT=8080

# Neon Postgres connection strings. See https://neon.tech - create a project,
# then copy both the pooled and direct connection strings from the dashboard.

# Pooled connection (PgBouncer) - used by the app/Prisma Client at runtime
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require&channel_binding=require"

# Direct (non-pooled) connection - used by Prisma Migrate
DIRECT_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require&channel_binding=require"
