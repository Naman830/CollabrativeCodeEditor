PORT=4000

# URL of the Piston sandboxed-execution instance this service proxies to.
# Defaults to the local Docker Compose Piston container.
PISTON_API_URL=http://localhost:2000

# Number of fixed worker pool workers processing queued execution jobs.
# Defaults to 4 if unset or invalid.
WORKER_POOL_SIZE=4

# Max time (ms) a single job may run against Piston before it is killed
# and rejected instead of hanging indefinitely. Defaults to 10000 (10s)
# if unset or invalid.
JOB_TIMEOUT_MS=10000

# Max number of jobs allowed to wait in the queue at once. When the queue
# is at this depth, new POST /execute requests are rejected immediately
# with a 429 instead of being queued indefinitely. Defaults to 100 if
# unset or invalid.
MAX_QUEUE_DEPTH=100

# --- Piston per-request resource limits ---
# These are injected into every /api/v2/execute request (overriding whatever
# the caller sent), enforced by Piston via the isolate sandbox's cgroups
# limits. See exec-server/README.md's "Resource limits" section for the
# full rationale.

# Max time (ms) the compile stage may run before Piston kills it.
# Defaults to 5000 (5s) if unset or invalid.
COMPILE_TIMEOUT_MS=5000

# Max time (ms) the run stage may run before Piston kills it.
# Defaults to 3000 (3s) if unset or invalid.
RUN_TIMEOUT_MS=3000

# Max memory (MB) the compile stage may use before Piston kills it.
# Defaults to 256 if unset or invalid.
COMPILE_MEMORY_LIMIT_MB=256

# Max memory (MB) the run stage may use before Piston kills it.
# Defaults to 128 if unset or invalid.
RUN_MEMORY_LIMIT_MB=128

# NOTE: max process/fork count has no per-request field in Piston's API —
# it's configured on the Piston server itself via PISTON_MAX_PROCESS_COUNT
# (see collab-code-editor/docker-compose.yml), not here.
